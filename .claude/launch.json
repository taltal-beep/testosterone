{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "FastAPI Backend",
      "runtimeExecutable": "/bin/sh",
      "runtimeArgs": ["-c", "set -a && . ./.env && set +a && .venv/bin/uvicorn testo_api.main:app --host 0.0.0.0 --port 8000 --reload"],
      "port": 8000
    },
    {
      "name": "React Frontend (Vite)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev"],
      "port": 5173
    }
  ]
}
